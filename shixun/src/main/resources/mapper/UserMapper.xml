<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.shixun.mapper.UserMapper">

    <select id="findAll" resultType="com.example.shixun.model.User">
        SELECT * FROM user ORDER BY id
    </select>

    <select id="findById" resultType="com.example.shixun.model.User">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <select id="findByUsername" resultType="com.example.shixun.model.User">
        SELECT * FROM user WHERE username = #{username}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, age, email, phone, password)
        VALUES (#{username}, #{age}, #{email}, #{phone}, #{password})
    </insert>

    <update id="update">
        UPDATE user SET username=#{username}, age=#{age}, email=#{email}, phone=#{phone}
        <if test="password != null and password != ''">
            , password=#{password}
        </if>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM user WHERE id = #{id}
    </delete>

</mapper>
